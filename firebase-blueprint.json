{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Representa uma barbearia (inquilino) no sistema SaaS.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "phone": { "type": "string" },
        "planId": { "type": "string" },
        "planStatus": { "type": "string", "enum": ["ACTIVE", "TRIAL", "CANCELED"] },
        "logoUrl": { "type": "string" },
        "backgroundUrl": { "type": "string" },
        "primaryColor": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "planId"]
    },
    "User": {
      "title": "User",
      "description": "Usuários do sistema (Dono, Barbeiro ou Cliente).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "OWNER", "BARBER", "CLIENT"] },
        "tenantId": { "type": "string" },
        "phone": { "type": "string" },
        "loyaltyPoints": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "Service": {
      "title": "Service",
      "description": "Serviços oferecidos pela barbearia.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["name", "price", "duration", "tenantId"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Agendamentos de serviços.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "clientId": { "type": "string" },
        "barberId": { "type": "string" },
        "serviceId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PENDING", "CONFIRMED", "COMPLETED", "CANCELED"] },
        "totalPrice": { "type": "number" }
      },
      "required": ["tenantId", "clientId", "barberId", "serviceId", "date", "status"]
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Configurações da barbearia."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Perfis de usuários."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Catálogo de serviços."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Registros de agendamentos."
    }
  }
}
